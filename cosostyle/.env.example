# ────────────────────────────────────────────────────────────────
# CoSoStyle Frontend — Environment Variables
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────

# Backend API URL
VITE_API_BASE_URL=http://localhost:5001/api

# Gemini AI API Key (for AI chatbot)
VITE_GEMINI_API_KEY=your_gemini_api_key_from_ai_studio

# Google Analytics (optional)
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Google OAuth Client ID (optional)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Razorpay Key ID (public key, safe for frontend)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx

# Site URL (used for OG/meta tags)
VITE_SITE_URL=https://cosostyle.com

# WhatsApp number for chat button
VITE_WHATSAPP_NUMBER=919999999999
