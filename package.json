{
  "name": "cosostyle-monorepo",
  "version": "1.0.0",
  "scripts": {
    "dev:frontend": "npm run dev --prefix cosostyle",
    "dev:server": "npm run dev --prefix server",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
    "start": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
    "install:all": "npm install && npm install --prefix cosostyle && npm install --prefix server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react-router-dom": "^7.18.0"
  }
}
