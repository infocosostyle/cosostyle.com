# ────────────────────────────────────────────────────────────────
# CoSoStyle Server — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ────────────────────────────────────────────────────────────────

# Server
PORT=5001
NODE_ENV=production

# JWT (use a long random secret in production)
JWT_SECRET=your_super_secret_jwt_key_at_least_64_characters_long_replace_this

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cosostyle?retryWrites=true&w=majority

# CORS origin (your frontend URL)
CORS_ORIGIN=https://cosostyle.com

# Email (Nodemailer / Gmail App Password — optional for real emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Razorpay Payment Gateway (optional for real payments)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Stripe Payment Gateway (optional)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# Google OAuth (optional for real Google login)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
